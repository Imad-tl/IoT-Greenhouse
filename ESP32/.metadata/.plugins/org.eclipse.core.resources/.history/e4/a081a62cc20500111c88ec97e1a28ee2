#include <stdio.h>
#include "freertos/FreeRTOS.h"
#include "freertos/task.h"
#include "esp_log.h"
#include "driver/temperature_sensor.h"

static const char *TAG = "TEMP";

void app_main(void)
{
    temperature_sensor_handle_t temp_handle = NULL;

    // Plage de mesure (large pour éviter les erreurs)
    temperature_sensor_config_t temp_cfg = TEMPERATURE_SENSOR_CONFIG_DEFAULT(10, 80);

    ESP_ERROR_CHECK(temperature_sensor_install(&temp_cfg, &temp_handle));
    ESP_ERROR_CHECK(temperature_sensor_enable(temp_handle));

    ESP_LOGI(TAG, "Capteur température interne activé");

    while (1) {
        float t = 0.0f;
        esp_err_t err = temperature_sensor_get_celsius(temp_handle, &t);

        if (err == ESP_OK) {
            // Affichage “propre” + stable
            ESP_LOGI(TAG, "Temp = %6.2f °C", t);
        } else {
            ESP_LOGE(TAG, "Lecture impossible: %s", esp_err_to_name(err));
        }

        vTaskDelay(pdMS_TO_TICKS(2000));
    }
}
