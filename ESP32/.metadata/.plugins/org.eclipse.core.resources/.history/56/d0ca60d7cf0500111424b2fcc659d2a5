#include <stdio.h>
#include "math.h"
#include "freertos/FreeRTOS.h"
#include "freertos/task.h"
#include "freertos/portmacro.h"
#include "driver/gpio.h"
#include "esp_rom_sys.h"
#include "esp_err.h"

#define DHT_GPIO GPIO_NUM_4

static inline uint32_t wait_level(gpio_num_t pin, int level, uint32_t timeout_us)
{
    uint32_t t = 0;
    while (gpio_get_level(pin) == level) {
        if (t++ >= timeout_us) return 0;
        esp_rom_delay_us(1);
    }
    return t;
}

// Retourne true si OK, false si fail (style Arduino)
static bool dht11_read(float *temp_c, float *hum_pct)
{
    uint8_t data[5] = {0};

    // Start signal
    gpio_set_direction(DHT_GPIO, GPIO_MODE_OUTPUT);
    gpio_set_level(DHT_GPIO, 0);
    vTaskDelay(pdMS_TO_TICKS(20));   // >= 18ms
    gpio_set_level(DHT_GPIO, 1);
    esp_rom_delay_us(30);

    // Input + pull-up
    gpio_set_direction(DHT_GPIO, GPIO_MODE_INPUT);
    gpio_set_pull_mode(DHT_GPIO, GPIO_PULLUP_ONLY);

    // Timing critical
    portMUX_TYPE mux = portMUX_INITIALIZER_UNLOCKED;
    portENTER_CRITICAL(&mux);

    // DHT response: 80us low, 80us high, then low
    if (!wait_level(DHT_GPIO, 1, 300)) { portEXIT_CRITICAL(&mux); return false; }
    if (!wait_level(DHT_GPIO, 0, 300)) { portEXIT_CRITICAL(&mux); return false; }
    if (!wait_level(DHT_GPIO, 1, 300)) { portEXIT_CRITICAL(&mux); return false; }

    // 40 bits
    for (int i = 0; i < 40; i++) {
        // ~50us low
        if (!wait_level(DHT_GPIO, 0, 150)) { portEXIT_CRITICAL(&mux); return false; }
        // high duration decides bit
        uint32_t high_us = wait_level(DHT_GPIO, 1, 250);
        if (high_us == 0) { portEXIT_CRITICAL(&mux); return false; }

        int bit = (high_us > 50) ? 1 : 0;
        data[i / 8] <<= 1;
        data[i / 8] |= bit;
    }

    portEXIT_CRITICAL(&mux);

    // checksum
    uint8_t sum = (uint8_t)(data[0] + data[1] + data[2] + data[3]);
    if (sum != data[4]) return false;

    // DHT11 values are integer
    *hum_pct = (float)data[0];
    *temp_c  = (float)data[2];
    return true;
}

void app_main(void)
{
    printf("DHT11 test on GPIO4\n");
    printf("If it fails: check VCC=3.3V, GND, DATA pin (S/OUT), pull-up\n\n");

    while (1) {
        float temp = NAN;
        float hum  = NAN;

        if (!dht11_read(&temp, &hum) || isnan(temp) || isnan(hum)) {
            printf("Failed to read from DHT11\n");
        } else {
            printf("Temperature: %.0f °C, Humidity: %.0f %%\n", temp, hum);
        }
        fflush(stdout);

        vTaskDelay(pdMS_TO_TICKS(5000));
    }
}
