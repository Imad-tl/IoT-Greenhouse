#include <stdio.h>
#include <string.h>
#include "freertos/FreeRTOS.h"
#include "freertos/task.h"
#include "esp_log.h"
#include "esp_err.h"
#include "driver/gpio.h"
#include "esp_rom_sys.h"

#define DHT_GPIO GPIO_NUM_4
#define DHT22    1   // 1 = DHT22/AM2302, 0 = DHT11

static const char *TAG = "DHT";

static inline uint32_t wait_level(gpio_num_t pin, int level, uint32_t timeout_us)
{
    uint32_t t = 0;
    while (gpio_get_level(pin) == level) {
        if (t++ >= timeout_us) return 0;
        esp_rom_delay_us(1);
    }
    return t;
}

static esp_err_t dht_read(float *temp_c, float *hum_pct)
{
    uint8_t data[5] = {0};

    // Start signal: pull low
    gpio_set_direction(DHT_GPIO, GPIO_MODE_OUTPUT);
    gpio_set_level(DHT_GPIO, 0);
#if DHT22
    esp_rom_delay_us(1100); // >1ms
#else
    esp_rom_delay_us(20000); // DHT11 needs ~18ms
#endif
    gpio_set_level(DHT_GPIO, 1);
    esp_rom_delay_us(30);

    // Switch to input (pull-up)
    gpio_set_direction(DHT_GPIO, GPIO_MODE_INPUT);
    gpio_set_pull_mode(DHT_GPIO, GPIO_PULLUP_ONLY);

    // Sensor response: low ~80us then high ~80us
    if (!wait_level(DHT_GPIO, 1, 100)) return ESP_ERR_TIMEOUT; // wait go low
    if (!wait_level(DHT_GPIO, 0, 100)) return ESP_ERR_TIMEOUT; // wait go high
    if (!wait_level(DHT_GPIO, 1, 100)) return ESP_ERR_TIMEOUT; // wait go low (start bits)

    // Read 40 bits
    for (int i = 0; i < 40; i++) {
        // Each bit: 50us low then high (26-28us => 0, ~70us => 1)
        if (!wait_level(DHT_GPIO, 0, 70)) return ESP_ERR_TIMEOUT;   // wait end of low
        uint32_t high_us = wait_level(DHT_GPIO, 1, 120);             // measure high
        if (high_us == 0) return ESP_ERR_TIMEOUT;

        int bit = (high_us > 50) ? 1 : 0;
        data[i / 8] <<= 1;
        data[i / 8] |= bit;
    }

    // Checksum
    uint8_t sum = data[0] + data[1] + data[2] + data[3];
    if (sum != data[4]) return ESP_ERR_INVALID_CRC;

#if DHT22
    int16_t raw_h = (data[0] << 8) | data[1];
    int16_t raw_t = (data[2] << 8) | data[3];
    if (raw_t & 0x8000) raw_t = -(raw_t & 0x7FFF);

    *hum_pct = raw_h / 10.0f;
    *temp_c  = raw_t / 10.0f;
#else
    *hum_pct = (float)data[0];
    *temp_c  = (float)data[2];
#endif

    return ESP_OK;
}

void app_main(void)
{
    ESP_LOGI(TAG, "Lecture DHT sur GPIO%d (%s)", (int)DHT_GPIO, DHT22 ? "DHT22" : "DHT11");

    while (1) {
        float t = 0.0f, h = 0.0f;
        esp_err_t err = dht_read(&t, &h);

        if (err == ESP_OK) {
            ESP_LOGI(TAG, "Temp: %6.2f °C | Hum: %6.2f %%", t, h);
        } else if (err == ESP_ERR_INVALID_CRC) {
            ESP_LOGW(TAG, "CRC invalide (bruit/câblage), retente...");
        } else {
            ESP_LOGW(TAG, "Timeout (capteur pas vu). Vérifie VCC/GND/DATA + pull-up.");
        }

        vTaskDelay(pdMS_TO_TICKS(2000));
    }
}
