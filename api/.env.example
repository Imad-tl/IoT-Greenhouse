# Django
DJANGO_SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,cloud,iot-cpe-craa.duckdns.org

# RabbitMQ
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=root
RABBITMQ_PASSWORD=root
RABBITMQ_VHOST=/

# InfluxDB
INFLUXDB_URL=http://influxdb3-core:8181
INFLUXDB_ORG=lorawan
INFLUXDB_BUCKET=lorawan_data
INFLUXDB_TOKEN=test-token

# Grafana
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# Security
API_KEY=your-api-key-change-me

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,http://grafana:3000
