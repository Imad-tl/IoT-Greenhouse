#include <stdio.h>
#include "freertos/FreeRTOS.h"
#include "freertos/task.h"
#include "driver/gpio.h"

// >>>> Mets ici les GPIO de ta LED
#define LED_R_GPIO  8
#define LED_G_GPIO  9

// 0 = cathode commune (GPIO=1 allume)
// 1 = anode commune (GPIO=0 allume)
#define COMMON_ANODE 0

static inline void led_set(gpio_num_t pin, int on)
{
#if COMMON_ANODE
    gpio_set_level(pin, on ? 0 : 1);
#else
    gpio_set_level(pin, on ? 1 : 0);
#endif
}

static void leds_init(void)
{
    gpio_config_t io = {
        .pin_bit_mask = (1ULL << LED_R_GPIO) | (1ULL << LED_G_GPIO),
        .mode = GPIO_MODE_OUTPUT,
        .pull_up_en = 0,
        .pull_down_en = 0,
        .intr_type = GPIO_INTR_DISABLE
    };
    gpio_config(&io);

    // éteint tout au départ
    led_set(LED_R_GPIO, 0);
    led_set(LED_G_GPIO, 0);
}

void app_main(void)
{
    leds_init();

    while (1) {
        // Rouge ON, Vert OFF
        led_set(LED_R_GPIO, 1);
        led_set(LED_G_GPIO, 0);
        vTaskDelay(pdMS_TO_TICKS(500));

        // Rouge OFF, Vert ON
        led_set(LED_R_GPIO, 0);
        led_set(LED_G_GPIO, 1);
        vTaskDelay(pdMS_TO_TICKS(500));
    }
}
