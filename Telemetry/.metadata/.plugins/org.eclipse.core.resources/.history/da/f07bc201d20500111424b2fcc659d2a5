#include <stdio.h>
#include "freertos/FreeRTOS.h"
#include "freertos/task.h"
#include "esp_log.h"
#include "esp_err.h"
#include "esp_adc/adc_oneshot.h"

static const char *TAG = "LDR";

// Mets ici le GPIO où tu as branché AO/SIG (doit être ADC-capable)
#define LDR_GPIO   GPIO_NUM_2   // <-- change si besoin

// Seuil brut (0..4095 environ). Ajuste après 2-3 tests.
#define THRESHOLD  2000

void app_main(void)
{
    adc_oneshot_unit_handle_t adc;
    adc_oneshot_unit_init_cfg_t init_cfg = {
        .unit_id = ADC_UNIT_1,
        .ulp_mode = ADC_ULP_MODE_DISABLE
    };
    ESP_ERROR_CHECK(adc_oneshot_new_unit(&init_cfg, &adc));

    adc_unit_t unit;
    adc_channel_t ch;
    ESP_ERROR_CHECK(adc_oneshot_io_to_channel(LDR_GPIO, &unit, &ch));
    if (unit != ADC_UNIT_1) {
        ESP_LOGE(TAG, "GPIO %d n'est pas sur ADC1. Change LDR_GPIO.", (int)LDR_GPIO);
        return;
    }

    adc_oneshot_chan_cfg_t ch_cfg = {
        .bitwidth = ADC_BITWIDTH_DEFAULT,
        .atten = ADC_ATTEN_DB_11
    };
    ESP_ERROR_CHECK(adc_oneshot_config_channel(adc, ch, &ch_cfg));

    ESP_LOGI(TAG, "LDR sur GPIO%d (ADC1_CH%d). Seuil=%d", (int)LDR_GPIO, (int)ch, THRESHOLD);

    while (1) {
        int raw = 0;
        ESP_ERROR_CHECK(adc_oneshot_read(adc, ch, &raw));

        if (raw > THRESHOLD) {
            printf("LUMIERE (raw=%d)\n", raw);
        } else {
            printf("SOMBRE  (raw=%d)\n", raw);
        }
        fflush(stdout);

        vTaskDelay(pdMS_TO_TICKS(500));
    }
}
